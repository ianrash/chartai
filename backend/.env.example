# ChartAI Backend Environment Variables
# Copy this to .env and fill in your values

# Required - Get from https://openrouter.ai/
OPENROUTER_API_KEY=

# Optional - Your frontend URL for CORS (defaults to chartai.netlify.app if not set)
REFERRER_URL=https://chartai.netlify.app

# Optional - Port (default: 10000)
PORT=10000

# Optional - Upload temp directory
UPLOADS_DIR=/tmp/chartai-uploads